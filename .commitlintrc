{
  "extends": [
    "@commitlint/config-conventional"
  ],
  "rules": {
    "body-full-stop": [
      2,
      "never",
      "."
    ],
    "type-enum": [
      2,
      "always",
      [
        "build",
        "chore",
        "ci",
        "docs",
        "feat",
        "fix",
        "perf",
        "refactor",
        "revert",
        "style",
        "test"
      ]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "books",
        "readings",
        "users",
        "infra",
        "env",
        "data",
        "config",
        "ui",
        "page",
        "hook",
        "router",
        "form",
        "service-layer",
        "layout",
        "tooling",
        "ai",
        "domain",
        "home"
      ]
    ],
    "subject-case": [
      2,
      "never",
      [
        "start-case",
        "pascal-case",
        "upper-case"
      ]
    ],
    "subject-full-stop": [
      2,
      "never",
      "."
    ]
  }
}
